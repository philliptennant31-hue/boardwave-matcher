# Anthropic
ANTHROPIC_API_KEY=
# Optional model override; defaults to claude-sonnet-4-6
ANTHROPIC_MODEL=

# Supabase — server-side (Netlify functions + seed script)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase — browser-side (Vite inlines VITE_* into the client bundle)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: enable the demo reset endpoint and UI button (set both to "1")
DEMO_RESET=
VITE_DEMO_RESET=
